{
  "name": "speelans-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Autism Support & Care Platform",
  "keywords": ["autism", "healthcare", "education", "accessibility", "nextjs"],
  "author": "Speelans AI Team",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "postinstall": "prisma generate",
    "clean": "rm -rf .next",
    "analyze": "ANALYZE=true npm run build",
    "docker:build": "docker build -t speelans-ai .",
    "docker:run": "docker run -p 3000:3000 speelans-ai",
    "health-check": "curl -f http://localhost:3000/api/health || exit 1"
  },
  "dependencies": {
    "@daily-co/daily-js": "^0.89.1",
    "@prisma/client": "^7.5.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@stripe/stripe-js": "^8.11.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.99.3",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-query": "^5.91.2",
    "@trpc/client": "^11.13.4",
    "@trpc/next": "^11.13.4",
    "@trpc/react-query": "^11.13.4",
    "@trpc/server": "^11.13.4",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "nanoid": "^5.1.7",
    "next": "^16.2.0",
    "postcss": "^8.5.8",
    "prisma": "^7.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.9.4",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}